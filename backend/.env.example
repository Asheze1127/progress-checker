# GitHub App installation authentication
GITHUB_APP_CLIENT_ID=
# Optional. Empty is fine because the code can resolve it from owner/repo.
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PEM=""
# GITHUB_APP_CLIENT_SECRET is not used for installation authentication.
# GITHUB_APP_CLIENT_SECRET=
# If you want to paste the PEM directly, use:
# GITHUB_APP_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----
# ...
# -----END RSA PRIVATE KEY-----"

# Optional for GitHub Enterprise Server
GITHUB_BASE_URL=

# Issue creation target
GITHUB_OWNER=Asheze1127
GITHUB_REPO=progress-checker
GITHUB_ISSUE_TITLE=
GITHUB_ISSUE_BODY=
GITHUB_ISSUE_LABELS=triage,bot
