# Server
PORT=8080

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=progress_checker
DATABASE_USER=postgres
DATABASE_PASS=CHANGE_ME_IN_PRODUCTION
DATABASE_SSL_MODE=require

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
# Channel ID for escalated question notifications to mentors
SLACK_MENTOR_CHANNEL_ID=C01MENTORCHANNEL

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=CHANGE_ME_must_be_at_least_32_bytes

# Encryption (16, 24, or 32 bytes for AES-128/192/256)
ENCRYPTION_KEY=CHANGE_ME_32_byte_encryption_key!

# Internal API
INTERNAL_TOKEN=CHANGE_ME_internal_api_token_32chars

# Frontend (for setup URL generation)
FRONTEND_BASE_URL=http://localhost:3000

# AWS
AWS_REGION=ap-northeast-1
# Local SQS endpoint (uncomment for local development with ElasticMQ)
# SQS_ENDPOINT=http://localhost:9324
# AWS_ACCESS_KEY_ID=local
# AWS_SECRET_ACCESS_KEY=local
