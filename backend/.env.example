# Server
PORT=8080

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=progress_checker
DATABASE_USER=postgres
DATABASE_PASS=postgres
DATABASE_SSL_MODE=disable

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
# Channel ID for escalated question notifications to mentors
SLACK_MENTOR_CHANNEL_ID=C01MENTORCHANNEL

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=your-jwt-secret-at-least-32-bytes-long

# Encryption (16, 24, or 32 bytes for AES-128/192/256)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Internal API
INTERNAL_TOKEN=your-internal-api-token

# Frontend (for setup URL generation)
FRONTEND_BASE_URL=http://localhost:3000
